# Mosaic - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================================================
# Supabase / Database
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For server-side / migration scripts (NOT exposed to client)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Application
# ============================================================
VITE_APP_URL=http://localhost:5173
# VITE_APP_NAME=Mosaic

# ============================================================
# Storage (for future self-hosting with S3/DO Spaces)
# ============================================================
# STORAGE_PROVIDER=supabase
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_BUCKET=mosaic-uploads
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ============================================================
# Security (for future self-hosting)
# ============================================================
# SESSION_SECRET=generate-a-strong-random-string
# ENCRYPTION_KEY=generate-a-32-byte-hex-key
# CSRF_SECRET=generate-another-strong-random-string
