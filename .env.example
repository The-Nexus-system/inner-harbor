# Mosaic — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================================================
# Supabase / Database (REQUIRED — client-safe, exposed to browser)
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# ============================================================
# Application (OPTIONAL — client-safe)
# ============================================================
VITE_APP_URL=http://localhost:5173
# VITE_APP_NAME=Mosaic

# Environment: development | staging | production
# Auto-detected if not set (DEV mode = development, builds = production)
# VITE_APP_ENV=production

# ============================================================
# Server-only secrets (NOT exposed to client — no VITE_ prefix)
# Used by migration scripts, edge functions, and backend tools.
# ============================================================
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Storage (for future self-hosting with S3/DO Spaces)
# ============================================================
# STORAGE_PROVIDER=supabase
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_BUCKET=mosaic-uploads
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ============================================================
# Security (for future self-hosting)
# ============================================================
# SESSION_SECRET=generate-a-strong-random-string
# ENCRYPTION_KEY=generate-a-32-byte-hex-key
# CSRF_SECRET=generate-another-strong-random-string
